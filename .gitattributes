# Normalize line endings to LF in the repository; checkout as native on each OS
* text=auto

# Force LF for source files (consistent across Windows/macOS/Linux contributors)
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.txt  text eol=lf

# Binary — never mangle
*.joblib binary
*.xlsx   binary
*.png    binary
*.jpg    binary
*.svg    text eol=lf
